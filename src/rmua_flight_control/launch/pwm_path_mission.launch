<launch>
  <arg name="drone_name" default="drone_1" />
  <arg name="source_root" default="/airsim_node" />
  <arg name="relay_root" default="/rmua/sensors" />
  <arg name="enable_obstacle_avoidance" default="true" />
  <arg name="raw_pose_setpoint_topic" default="/rmua/control/path/raw_pose_setpoint" />
  <arg name="safe_pose_setpoint_topic" default="/rmua/control/basic/pose_setpoint" />
  <arg name="hover_altitude_m" default="1.0" />
  <arg name="path_csv" default="/home/hao/workspace-RosNoetic/rmua2026/drone_path.csv" />
  <arg name="target_waypoint_index" default="-1" />
  <arg name="keep_runtime_alive" default="true" />
  <arg name="failure_abort_on_detection" default="false" />
  <arg name="stable_point_indices" default="69" />
  <arg name="stable_point_hold_time_s" default="3.0" />
  <arg name="stable_point_brake_trigger_distance_m" default="1.0" />
  <arg name="lookahead_distance_m" default="16.0" />
  <arg name="min_lookahead_distance_m" default="3.0" />
  <arg name="lookahead_error_reduction_gain" default="1.5" />
  <arg name="turn_preview_distance_m" default="30.0" />
  <arg name="turn_min_lookahead_distance_m" default="3.0" />
  <arg name="turn_lookahead_min_scale" default="0.20" />
  <arg name="turn_angle_reduction_gain" default="4.5" />
  <arg name="turn_short_segment_ignore_distance_m" default="4.0" />
  <arg name="terminal_lookahead_distance_m" default="0.0" />
  <arg name="terminal_slowdown_distance_m" default="30.0" />
  <arg name="hover_pwm_estimate_override" default="0.265" />
  <arg name="max_angle_rad" default="1.05" />
  <arg name="tilt_compensation_min_cos" default="0.6" />
  <arg name="waypoint_acceptance_radius_m" default="3.0" />
  <arg name="final_acceptance_radius_m" default="3.0" />
  <arg name="completion_hold_time_s" default="2.0" />
  <arg name="failure_progress_stall_timeout_s" default="3.0" />
  <arg name="failure_stall_motion_radius_m" default="1.5" />
  <arg name="failure_distance_improvement_m" default="1.5" />
  <arg name="failure_min_distance_to_goal_m" default="12.0" />
  <arg name="failure_zero_pwm_timeout_s" default="1.0" />
  <arg name="failure_zero_pwm_threshold" default="0.08" />
  <arg name="failure_zero_pwm_min_progress" default="8" />
  <arg name="failure_grace_period_s" default="8.0" />
  <arg name="climb_priority_threshold_m" default="1.0" />
  <arg name="climb_horizontal_leash_m" default="3.0" />
  <arg name="climb_horizontal_leash_scale" default="0.5" />
  <arg name="climb_horizontal_leash_max_m" default="12.0" />
  <arg name="climb_vertical_release_distance_m" default="6.0" />
  <arg name="climb_vertical_step_m" default="6.0" />
  <arg name="climb_preview_waypoints" default="1" />
  <arg name="descent_release_distance_m" default="0.0" />

  <include file="$(find rmua_flight_control)/launch/pwm_hover_stack.launch">
    <arg name="drone_name" value="$(arg drone_name)" />
    <arg name="source_root" value="$(arg source_root)" />
    <arg name="relay_root" value="$(arg relay_root)" />
    <arg name="pose_setpoint_topic" value="$(arg safe_pose_setpoint_topic)" />
    <arg name="hover_altitude_m" value="$(arg hover_altitude_m)" />
    <arg name="hover_pwm_estimate_override" value="$(arg hover_pwm_estimate_override)" />
    <arg name="max_angle_rad" value="$(arg max_angle_rad)" />
    <arg name="tilt_compensation_min_cos" value="$(arg tilt_compensation_min_cos)" />
  </include>

  <include file="$(find rmua_flight_control)/launch/obstacle_avoidance.launch">
    <arg name="enable_avoidance" value="$(arg enable_obstacle_avoidance)" />
    <arg name="raw_pose_setpoint_topic" value="$(arg raw_pose_setpoint_topic)" />
    <arg name="safe_pose_setpoint_topic" value="$(arg safe_pose_setpoint_topic)" />
    <arg name="pose_topic" value="$(arg relay_root)/$(arg drone_name)/pose_gt" />
    <arg name="imu_topic" value="$(arg relay_root)/$(arg drone_name)/imu" />
    <arg name="lidar_topic" value="$(arg relay_root)/$(arg drone_name)/lidar" />
  </include>

  <node pkg="rmua_flight_control" type="path_mission_node" name="path_mission_node" output="screen" respawn="true" respawn_delay="2.0">
    <param name="path_csv" value="$(arg path_csv)" />
    <param name="pose_topic" value="$(arg relay_root)/$(arg drone_name)/pose_gt" />
    <param name="pose_setpoint_topic" value="$(arg raw_pose_setpoint_topic)" />
    <param name="enable_topic" value="/rmua/control/basic/enable" />
    <param name="world_frame_id" value="world_ned" />
    <param name="target_waypoint_index" value="$(arg target_waypoint_index)" />
    <param name="publish_rate_hz" value="20.0" />
    <param name="keep_runtime_alive" value="$(arg keep_runtime_alive)" />
    <param name="stable_point_indices" value="$(arg stable_point_indices)" />
    <param name="stable_point_hold_time_s" value="$(arg stable_point_hold_time_s)" />
    <param name="stable_point_brake_trigger_distance_m" value="$(arg stable_point_brake_trigger_distance_m)" />
    <param name="lookahead_distance_m" value="$(arg lookahead_distance_m)" />
    <param name="min_lookahead_distance_m" value="$(arg min_lookahead_distance_m)" />
    <param name="lookahead_error_reduction_gain" value="$(arg lookahead_error_reduction_gain)" />
    <param name="turn_preview_distance_m" value="$(arg turn_preview_distance_m)" />
    <param name="turn_min_lookahead_distance_m" value="$(arg turn_min_lookahead_distance_m)" />
    <param name="turn_lookahead_min_scale" value="$(arg turn_lookahead_min_scale)" />
    <param name="turn_angle_reduction_gain" value="$(arg turn_angle_reduction_gain)" />
    <param name="turn_short_segment_ignore_distance_m" value="$(arg turn_short_segment_ignore_distance_m)" />
    <param name="terminal_lookahead_distance_m" value="$(arg terminal_lookahead_distance_m)" />
    <param name="terminal_slowdown_distance_m" value="$(arg terminal_slowdown_distance_m)" />
    <param name="waypoint_acceptance_radius_m" value="$(arg waypoint_acceptance_radius_m)" />
    <param name="final_acceptance_radius_m" value="$(arg final_acceptance_radius_m)" />
    <param name="completion_hold_time_s" value="$(arg completion_hold_time_s)" />
    <param name="rotor_pwm_topic" value="$(arg relay_root)/$(arg drone_name)/debug/rotor_pwm" />
    <param name="failure_abort_on_detection" value="$(arg failure_abort_on_detection)" />
    <param name="failure_progress_stall_timeout_s" value="$(arg failure_progress_stall_timeout_s)" />
    <param name="failure_stall_motion_radius_m" value="$(arg failure_stall_motion_radius_m)" />
    <param name="failure_distance_improvement_m" value="$(arg failure_distance_improvement_m)" />
    <param name="failure_min_distance_to_goal_m" value="$(arg failure_min_distance_to_goal_m)" />
    <param name="failure_zero_pwm_timeout_s" value="$(arg failure_zero_pwm_timeout_s)" />
    <param name="failure_zero_pwm_threshold" value="$(arg failure_zero_pwm_threshold)" />
    <param name="failure_zero_pwm_min_progress" value="$(arg failure_zero_pwm_min_progress)" />
    <param name="failure_grace_period_s" value="$(arg failure_grace_period_s)" />
    <param name="climb_priority_threshold_m" value="$(arg climb_priority_threshold_m)" />
    <param name="climb_horizontal_leash_m" value="$(arg climb_horizontal_leash_m)" />
    <param name="climb_horizontal_leash_scale" value="$(arg climb_horizontal_leash_scale)" />
    <param name="climb_horizontal_leash_max_m" value="$(arg climb_horizontal_leash_max_m)" />
    <param name="climb_vertical_release_distance_m" value="$(arg climb_vertical_release_distance_m)" />
    <param name="climb_vertical_step_m" value="$(arg climb_vertical_step_m)" />
    <param name="climb_preview_waypoints" value="$(arg climb_preview_waypoints)" />
    <param name="descent_release_distance_m" value="$(arg descent_release_distance_m)" />
    <param name="enable_controller_on_start" value="true" />
  </node>
</launch>